{
  "name": "taskwright",
  "displayName": "Taskwright",
  "description": "Agentic task board for VS Code — triage work and dispatch isolated Claude Code sessions per task, on a git-native Backlog.md backbone.",
  "version": "0.0.1",
  "publisher": "ChronoVortex07",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChronoVortex07/taskwright"
  },
  "homepage": "https://github.com/ChronoVortex07/taskwright#readme",
  "bugs": {
    "url": "https://github.com/ChronoVortex07/taskwright/issues"
  },
  "keywords": [
    "backlog",
    "kanban",
    "tasks",
    "todo",
    "project management",
    "markdown",
    "ai agents",
    "claude code",
    "mcp",
    "worktrees"
  ],
  "engines": {
    "vscode": "^1.110.0",
    "node": ">=22"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "workspaceContains:**/backlog/tasks/*.md",
    "workspaceContains:**/backlog/config.yml",
    "workspaceContains:**/backlog/config.yaml",
    "workspaceContains:**/.backlog/tasks/*.md",
    "workspaceContains:**/.backlog/config.yml",
    "workspaceContains:**/.backlog/config.yaml",
    "workspaceContains:backlog.config.yml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Taskwright",
      "properties": {
        "taskwright.taskIdDisplay": {
          "type": "string",
          "enum": [
            "full",
            "number",
            "hidden"
          ],
          "default": "full",
          "description": "Controls how task IDs are shown in task cards and list rows: full (TASK-123), number (123), or hidden."
        },
        "taskwright.claimIdentity": {
          "type": "string",
          "default": "",
          "markdownDescription": "Identity that advisory task claims are attributed to (e.g. `@alice`). When empty, your OS username is used, prefixed with `@`."
        },
        "taskwright.claimStalenessHours": {
          "type": "number",
          "default": 12,
          "minimum": 0,
          "markdownDescription": "Hours after which another session's advisory claim is treated as stale (abandoned): stale claims are shown as such and can be re-claimed without an override prompt. Set to `0` to disable staleness (every live claim by another identity then requires confirmation to override)."
        },
        "taskwright.dispatchTemplate": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "",
          "markdownDescription": "Template for the dispatch prompt copied to the clipboard. Supports `{{id}}`, `{{title}}`, `{{status}}`, `{{priority}}`, `{{labels}}`, `{{description}}`, `{{acceptanceCriteria}}`, `{{plan}}`, `{{worktree}}`, and `{{filePath}}`. Leave empty to use the built-in template."
        },
        "taskwright.dispatchCreateWorktree": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Dispatch each task into its own isolated git worktree at `.worktrees/<branch>` (the default), so parallel sessions never share a working directory or active task. Set to `false` to dispatch into the workspace root instead. Falls back to the workspace root automatically when the folder is not a git repository."
        },
        "taskwright.dispatchOpenTerminal": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "When dispatching a task creates a worktree, open an integrated terminal in that worktree directory."
        },
        "taskwright.dispatchTerminalCommand": {
          "type": "string",
          "default": "",
          "markdownDescription": "When a dispatch opens a worktree terminal (`taskwright.dispatchOpenTerminal`), run this command in it. Supports the dispatch placeholders, notably `{{handoffFile}}` (path to the saved prompt) plus `{{id}}`, `{{title}}`, `{{worktree}}`. Leave empty to just open the terminal. To auto-start a session, use an **interactive** Claude Code chat seeded from the handoff file — e.g. bash: `claude \"$(cat {{handoffFile}})\"`, PowerShell: `claude (Get-Content -Raw '{{handoffFile}}')`. Commands using `claude -p`/`--print` (headless/metered) are skipped with a warning."
        },
        "taskwright.intakeTemplate": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "",
          "markdownDescription": "Template for the \"Categorize with Claude\" intake prompt. Supports `{{dump}}` (your raw notes), `{{labels}}`, `{{statuses}}`, and `{{priorities}}` (the board's vocabulary). Leave empty to use the built-in template."
        }
      }
    },
    "commands": [
      {
        "command": "taskwright.init",
        "title": "Taskwright: Initialize Backlog"
      },
      {
        "command": "taskwright.openKanban",
        "title": "Taskwright: Open Kanban Board"
      },
      {
        "command": "taskwright.openTasksInEditor",
        "title": "Taskwright: Open Board in Editor Tab",
        "icon": "$(link-external)"
      },
      {
        "command": "taskwright.openTaskList",
        "title": "Taskwright: Open Task List"
      },
      {
        "command": "taskwright.openDashboard",
        "title": "Taskwright: Open Dashboard"
      },
      {
        "command": "taskwright.refresh",
        "title": "Taskwright: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "taskwright.openTaskDetail",
        "title": "Taskwright: Open Task Detail"
      },
      {
        "command": "taskwright.createTask",
        "title": "Taskwright: Create Task",
        "icon": "$(add)"
      },
      {
        "command": "taskwright.createMilestone",
        "title": "Taskwright: Create Milestone",
        "icon": "$(milestone)"
      },
      {
        "command": "taskwright.openMarkdown",
        "title": "Taskwright: Open Task Markdown"
      },
      {
        "command": "taskwright.showListView",
        "title": "Switch to List View",
        "icon": "$(list-flat)"
      },
      {
        "command": "taskwright.showKanbanView",
        "title": "Switch to Kanban View",
        "icon": "$(layout)"
      },
      {
        "command": "taskwright.showDraftsView",
        "title": "Switch to Drafts View",
        "icon": "$(edit)"
      },
      {
        "command": "taskwright.showArchivedView",
        "title": "Switch to Archived View",
        "icon": "$(archive)"
      },
      {
        "command": "taskwright.showDocsView",
        "title": "Taskwright: Show Documents"
      },
      {
        "command": "taskwright.showDecisionsView",
        "title": "Taskwright: Show Decisions"
      },
      {
        "command": "taskwright.openDocumentDetail",
        "title": "Taskwright: Open Document Detail"
      },
      {
        "command": "taskwright.openDecisionDetail",
        "title": "Taskwright: Open Decision Detail"
      },
      {
        "command": "taskwright.selectBacklog",
        "title": "Taskwright: Select Active Backlog"
      },
      {
        "command": "taskwright.setupAgentIntegration",
        "title": "Taskwright: Set Up Backlog.md CLI"
      },
      {
        "command": "taskwright.claimTask",
        "title": "Taskwright: Claim Task",
        "icon": "$(lock)"
      },
      {
        "command": "taskwright.releaseTask",
        "title": "Taskwright: Release Task",
        "icon": "$(unlock)"
      },
      {
        "command": "taskwright.setActiveTask",
        "title": "Taskwright: Set Active Task (for agent)",
        "icon": "$(target)"
      },
      {
        "command": "taskwright.clearActiveTask",
        "title": "Taskwright: Clear Active Task"
      },
      {
        "command": "taskwright.dispatchTask",
        "title": "Taskwright: Dispatch Task (copy prompt)",
        "icon": "$(rocket)"
      },
      {
        "command": "taskwright.categorizeWithClaude",
        "title": "Taskwright: Categorize with Claude (copy prompt)",
        "icon": "$(sparkle)"
      },
      {
        "command": "taskwright.attachPlan",
        "title": "Taskwright: Attach Plan to Task",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "taskwright.detachPlan",
        "title": "Taskwright: Detach Plan from Task"
      },
      {
        "command": "taskwright.setupClaudeIntegration",
        "title": "Taskwright: Set Up Claude Code Integration (MCP + CLAUDE.md)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "taskwright.openTasksInEditor",
          "when": "view == taskwright.kanban",
          "group": "navigation@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taskwright",
          "title": "Taskwright",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "taskwright": [
        {
          "type": "webview",
          "id": "taskwright.kanban",
          "name": "Tasks",
          "icon": "images/view-kanban.svg"
        },
        {
          "type": "webview",
          "id": "taskwright.taskPreview",
          "name": "Details",
          "icon": "images/view-task-preview.svg",
          "visibility": "visible"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run build",
    "compile": "bun scripts/build.ts",
    "compile:webview": "vite build --config vite.webview.config.ts",
    "watch": "bun scripts/build.ts --watch",
    "build:css": "tailwindcss -i ./src/webview/styles.css -o ./dist/webview/styles.css",
    "build": "bun run build:css && bun run compile:webview && bun run compile",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bun run build && tsc -p tsconfig.e2e.json && bash scripts/run-e2e.sh",
    "test:cdp": "bun run build && bash scripts/run-cdp-tests.sh",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "proof": "bun run build && playwright test dispatch.spec board-indicators.spec",
    "demo:cross-branch-setup": "bash scripts/setup-cross-branch-demo.sh",
    "webview:serve": "vite",
    "check:engines": "bun scripts/check-engine-version.ts",
    "lint": "eslint src e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "package": "bunx @vscode/vsce package --no-dependencies",
    "licenses:generate": "bash scripts/generate-licenses.sh",
    "licenses:check": "bash scripts/check-licenses.sh",
    "depcheck": "depcheck",
    "ci": "bun run check:engines && bun run lint && bun run typecheck && bun run depcheck && bun run licenses:check && bun run test && bun run build && bun run test:playwright && bun run test:cdp && bun run test:e2e",
    "update:actions": "bunx actions-up@v1.12.0 --min-age 7",
    "screenshots": "bash scripts/screenshots/run.sh",
    "screenshots:validate": "bun scripts/screenshots/validate.ts",
    "release": "release-it",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.{ts,js,json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@release-it/keep-a-changelog": "^7.1.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/cli": "^4.3.0",
    "@types/chai": "^5.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.3",
    "@types/vscode": "1.110.0",
    "chai": "^6.2.2",
    "depcheck": "^1.4.7",
    "esbuild": "^0.27.7",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "generate-license-file": "^4.2.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "oxipng-bin": "^1.0.0",
    "prettier": "^3.8.4",
    "release-it": "^20.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "vscode-extension-tester": "^8.23.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "marked": "^17.0.6",
    "mermaid": "^11.15.0",
    "svelte": "^5.56.3",
    "tiny-markdown-editor": "^0.2.28",
    "zod": "^4.4.3"
  }
}
